---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroMosaic from '../components/HeroMosaic.astro';
import PostListItem from '../components/PostListItem.astro';
import SidebarCategories from '../components/SidebarCategories.astro';
import CategoryColumn from '../components/CategoryColumn.astro';
import { SITE } from '../site.config.mjs';
import { getPublishedPosts, getActiveClusters } from '../lib/posts.mjs';

const posts = await getPublishedPosts();
const clusters = await getActiveClusters();
const mosaicPosts = posts.slice(0, 3);
const listPosts = posts.slice(3, 12);

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  inLanguage: 'pt-BR'
};
---
<BaseLayout title={`${SITE.name} — ${SITE.tagline}`} description={SITE.description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <div class="container">
    <h1 class="page-h1">{SITE.tagline}</h1>
    <HeroMosaic posts={mosaicPosts} />
  </div>

  <div class="container layout-2col">
    <main>
      {listPosts.length > 0 && (
        <section class="panel">
          <h2 class="panel-title">Novas postagens</h2>
          <div class="list-items">
            {listPosts.map((post) => <PostListItem post={post} />)}
          </div>
        </section>
      )}

      {clusters.length > 0 && (
        <section class="cat-grid">
          {clusters.map((c) => (
            <CategoryColumn cluster={c} posts={posts.filter((p) => p.data.cluster === c.slug)} />
          ))}
        </section>
      )}
    </main>

    <aside class="sidebar">
      {clusters.length > 0 && <SidebarCategories clusters={clusters} />}
      <div class="widget widget-about">
        <h2 class="widget-title">Sobre o {SITE.name}</h2>
        <p>Só publicamos o que testamos: tutoriais de automação com passo a passo real, guias de IA sem hype e a história das invenções que criaram o mundo automatizado.</p>
        <p><a href="/sobre/">Conheça o projeto →</a></p>
      </div>
    </aside>
  </div>
</BaseLayout>
