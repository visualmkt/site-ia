---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE } from '../site.config.mjs';
import { getPublishedPosts, getActiveClusters } from '../lib/posts.mjs';

const posts = await getPublishedPosts();
const clusters = await getActiveClusters();
const latest = posts.slice(0, 6);

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  inLanguage: 'pt-BR'
};
---
<BaseLayout title={`${SITE.name} — ${SITE.tagline}`} description={SITE.description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <section class="hero">
    <div class="container">
      <h1>{SITE.tagline}</h1>
      <p>{SITE.description}</p>
    </div>
  </section>

  {latest.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">Últimos artigos</h2>
        <div class="grid">
          {latest.map((post) => <PostCard post={post} />)}
        </div>
      </div>
    </section>
  )}

  {clusters.map((c, i) => {
    const clusterPosts = posts.filter((p) => p.data.cluster === c.slug).slice(0, 4);
    return (
      <section class="section" style={i % 2 === 0 ? 'background: var(--bg-soft);' : ''}>
        <div class="container">
          <h2 class="section-title"><a href={`/${c.slug}/`} class="section-link">{c.title}</a></h2>
          <p class="section-desc">{c.description}</p>
          <div class="grid">
            {clusterPosts.map((post) => <PostCard post={post} />)}
          </div>
          <p class="more-link"><a href={`/${c.slug}/`}>Ver todos os artigos de {c.label} →</a></p>
        </div>
      </section>
    );
  })}

  <section class="section">
    <div class="container">
      <h2 class="section-title">Sobre o {SITE.name}</h2>
      <p style="max-width: 720px; color: var(--text-soft);">
        Aqui a regra é uma só: <strong>só publicamos o que testamos</strong>. Tutoriais de automação com passo a passo real,
        guias de IA sem hype e a história das invenções que criaram o mundo automatizado.
        <a href="/sobre/">Conheça o projeto</a> ou <a href="/contato/">fale com a gente</a>.
      </p>
    </div>
  </section>
</BaseLayout>
