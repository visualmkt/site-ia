---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import PostCard from '../../components/PostCard.astro';
import AuthorBox from '../../components/AuthorBox.astro';
import Comments from '../../components/Comments.astro';
import SidebarCategories from '../../components/SidebarCategories.astro';
import { SITE } from '../../site.config.mjs';
import { getPublishedPosts, getActiveClusters } from '../../lib/posts.mjs';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => (import.meta.env.PROD ? !data.draft : true));
  const allSorted = posts.slice().sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return posts.map((post) => {
    const i = allSorted.findIndex((p) => p.id === post.id);
    return {
      params: { cluster: post.data.cluster, slug: post.id },
      props: { post, prevPost: allSorted[i + 1] ?? null, nextPost: i > 0 ? allSorted[i - 1] : null }
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
const cluster = SITE.clusters[post.data.cluster];
const canonical = new URL(`/${post.data.cluster}/${post.id}/`, SITE.url).href;
const clusters = await getActiveClusters();

const fmt = (d: Date) => d.toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' });

const related = (await getCollection('posts', ({ data }) =>
  data.cluster === post.data.cluster && (import.meta.env.PROD ? !data.draft : true)
))
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const articleSchema: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  inLanguage: 'pt-BR',
  mainEntityOfPage: canonical,
  author: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  publisher: { '@type': 'Organization', name: SITE.name, url: SITE.url }
};
if (post.data.image) articleSchema.image = new URL(post.data.image, SITE.url).href;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: SITE.name, item: SITE.url },
    { '@type': 'ListItem', position: 2, name: cluster?.label ?? post.data.cluster, item: new URL(`/${post.data.cluster}/`, SITE.url).href },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: canonical }
  ]
};
---
<BaseLayout
  title={`${post.data.title} | ${SITE.name}`}
  description={post.data.description}
  ogType="article"
  ogImage={post.data.image}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <header class="article-header">
    <nav class="breadcrumbs" aria-label="Você está em">
      <a href="/">Início</a> › <a href={`/${post.data.cluster}/`}>{cluster?.label ?? post.data.cluster}</a>
    </nav>
    <h1>{post.data.title}</h1>
    <p class="article-meta">
      Publicado em {fmt(post.data.pubDate)}
      {post.data.updatedDate && <> · Atualizado em {fmt(post.data.updatedDate)}</>}
    </p>
    {post.data.image && <img class="cover-img" src={post.data.image} alt={post.data.imageAlt ?? post.data.title} loading="eager" />}
  </header>

  <div class="container layout-2col">
    <main>
      <div class="article-body">
        <Content />
        <AdSlot />
        <p class="hub-cta">
          Quer mais sobre o assunto? Veja <a href={`/${post.data.cluster}/`}>todos os artigos de {cluster?.label ?? post.data.cluster}</a>
          {' '}ou <a href="/artigos/">a lista completa de artigos</a>.
        </p>
        <AuthorBox />
      </div>

      {(prevPost || nextPost) && (
        <nav class="article-nav" aria-label="Navegação entre artigos">
          {prevPost ? (
            <a class="article-nav-link article-nav-prev" href={`/${prevPost.data.cluster}/${prevPost.id}/`}>
              <span class="article-nav-label">← Artigo anterior</span>
              <span class="article-nav-title">{prevPost.data.title}</span>
            </a>
          ) : <span />}
          {nextPost ? (
            <a class="article-nav-link article-nav-next" href={`/${nextPost.data.cluster}/${nextPost.id}/`}>
              <span class="article-nav-label">Próximo artigo →</span>
              <span class="article-nav-title">{nextPost.data.title}</span>
            </a>
          ) : <span />}
        </nav>
      )}

      {related.length > 0 && (
        <aside class="related">
          <h2>Leia também</h2>
          <div class="grid">
            {related.map((p) => <PostCard post={p} />)}
          </div>
        </aside>
      )}

      <div class="container">
        <Comments />
      </div>
    </main>

    <aside class="sidebar">
      {clusters.length > 0 && <SidebarCategories clusters={clusters} />}
      <div class="widget widget-about">
        <h2 class="widget-title">Sobre o {SITE.name}</h2>
        <p>Só publicamos o que testamos: tutoriais de automação com passo a passo real, guias de IA sem hype e a história das invenções que criaram o mundo automatizado.</p>
        <p><a href="/sobre/">Conheça o projeto →</a></p>
      </div>
    </aside>
  </div>

  <script is:inline>
    // Índice do artigo (TOC) gerado dos H2 — melhora navegação e tempo na página
    document.addEventListener('DOMContentLoaded', function () {
      var body = document.querySelector('.article-body');
      if (!body) return;
      var hs = body.querySelectorAll('h2');
      if (hs.length < 3) return;
      var items = '';
      hs.forEach(function (h, i) {
        if (!h.id) {
          h.id = 's' + (i + 1) + '-' + h.textContent.toLowerCase().normalize('NFD')
            .replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 60);
        }
        items += '<li><a href="#' + h.id + '">' + h.textContent + '</a></li>';
      });
      var toc = document.createElement('nav');
      toc.className = 'toc';
      toc.setAttribute('aria-label', 'Índice do artigo');
      toc.innerHTML = '<strong>Neste artigo</strong><ol>' + items + '</ol>';
      body.insertBefore(toc, body.firstChild);
    });
  </script>
</BaseLayout>
